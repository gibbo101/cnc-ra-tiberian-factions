<?xml version="1.0"?>
<!--
    Tiberian Factions -- client constant overrides.

    ClientG.exe looks for DATA\XML\GameConstants_Mod.xml by name (the literal is in the
    binary) and merges it over the base GameConstants. Additive, so there is no same-size
    rule and no CONFIG.MEG repack for anything set here. Documented by Kushan on PPM
    (ppmforums.com/topic-54809) and used by Vanilla Conquer's TD sample for megamaps.

    `overwrite="true"` is required to REPLACE a list rather than append to it.
-->
<GameConstants>
    <GameConstantsClass>

        <!-- HD only. The mod's TD and TS content has no classic art path, so classic
             renders broken; this removes the option and the spacebar toggle with it. -->
        <CNCDisableLegacyGraphicsOption network="client"> True </CNCDisableLegacyGraphicsOption>

        <!-- Exposes Mod Command 1-4 in Options > Controls, handled in dllinterface.cpp.
             Players must bind them themselves -- there is no file-based default binding
             (measured 2026-07-21: the client ignores InputTranslatorConfigurations.xml
             from a mod, in the MEG, loose, and on a freshly created profile). -->
        <CNCEnableModHotKeyGameCommands network="client"> True </CNCEnableModHotKeyGameCommands>

        <!-- That lobby checkbox carries Unholy Alliance, so it starts unticked. -->
        <CNCAllowAftermathDefault> false </CNCAllowAftermathDefault>

        <!-- Pixel-perfect zoom: 11 steps rather than vanilla's 8, and zooms further out.
             bleid's values via CFE Patch Redux commit ea2dde5, GPL v3. -->
        <CNCZoomFactors network="client" overwrite="true">
            <ZoomFactor>0.246875</ZoomFactor>
            <ZoomFactor>0.37</ZoomFactor>
            <ZoomFactor>0.49375</ZoomFactor>
            <ZoomFactor>0.74</ZoomFactor>
            <ZoomFactor>0.9875</ZoomFactor>
            <ZoomFactor>1.11</ZoomFactor>
            <ZoomFactor>1.234375</ZoomFactor>
            <ZoomFactor>1.48</ZoomFactor>
            <ZoomFactor>1.728125</ZoomFactor>
            <ZoomFactor>1.85</ZoomFactor>
            <ZoomFactor>1.975</ZoomFactor>
        </CNCZoomFactors>

    </GameConstantsClass>
</GameConstants>
